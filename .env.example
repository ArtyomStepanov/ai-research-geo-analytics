# --- Внешний OpenAI ---
OPENAI_API_KEY=your_key_here

# --- ИЛИ self-hosted LLM (OpenAI-совместимый endpoint) ---
# Примеры:
#   Ollama:     LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL=llama3.1:8b
#   vLLM:       LLM_BASE_URL=http://localhost:8000/v1  LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
#   LM Studio:  LLM_BASE_URL=http://localhost:1234/v1  LLM_MODEL=<имя загруженной модели>
# Если LLM_BASE_URL задан — OPENAI_API_KEY можно не задавать (или поставить любую строку).
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1:8b
